rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: only the authenticated user matching the doc owner can read/write
    function isOwner(email) {
      return request.auth != null && request.auth.token.email == email;
    }

    // Users collection: each user can only access their own document and sub-collections
    match /users/{userEmail} {
      allow read, write: if isOwner(userEmail);

      match /transactions/{txId} {
        allow read, write: if isOwner(userEmail);
      }

      match /categories/{catId} {
        allow read, write: if isOwner(userEmail);
      }

      match /budgets/{catId} {
        allow read, write: if isOwner(userEmail);
      }

      match /recurring_payments/{paymentId} {
        allow read, write: if isOwner(userEmail);
      }

      match /notifications/{notifId} {
        allow read, write: if isOwner(userEmail);
      }

      match /lent_money/{entryId} {
        allow read, write: if isOwner(userEmail);
      }

      match /wealth/{docId} {
        allow read, write: if isOwner(userEmail);
      }

      match /category_rules/{ruleId} {
        allow read, write: if isOwner(userEmail);
      }
    }

    // Admin: only admin users (isAdmin == true in their own doc) can read all users
    match /users/{userEmail} {
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.isAdmin == true;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
