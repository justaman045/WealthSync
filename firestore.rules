rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(email) {
      return request.auth != null && request.auth.token.email == email;
    }

    function isAdmin() {
      let adminDoc = get(/databases/$(database)/documents/users/$(request.auth.token.email));
      return request.auth != null
          && adminDoc != null
          && adminDoc.data != null
          && adminDoc.data.isAdmin == true;
    }

    function validTransaction() {
      let d = request.resource.data;
      return d.keys().hasAll(['amount', 'date', 'senderId', 'recipientId'])
          && d.amount is number
          && d.date is timestamp;
    }

    function isReferralAllowed() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      let isReferralFields = affected.hasOnly(['referralCount', 'subscriptionStatus', 'trialEndDate']);
      let targetHasCode = resource.data.keys().hasAny(['referralCode']);
      return request.auth != null && targetHasCode && isReferralFields;
    }

    match /users/{userEmail} {
      allow read: if isOwner(userEmail) || isAdmin();
      allow write: if isOwner(userEmail) || isReferralAllowed();

      match /transactions/{txId} {
        allow read: if isOwner(userEmail) || isAdmin();
        allow write: if isOwner(userEmail) && (request.method == 'delete' || validTransaction());
      }

      match /categories/{catId} {
        allow read, write: if isOwner(userEmail);
      }

      match /budgets/{catId} {
        allow read, write: if isOwner(userEmail);
      }

      match /recurring_payments/{paymentId} {
        allow read, write: if isOwner(userEmail);
      }

      match /notifications/{notifId} {
        allow read, write: if isOwner(userEmail);
      }

      match /lent_money/{entryId} {
        allow read, write: if isOwner(userEmail);
      }

      match /wealth/{docId} {
        allow read, write: if isOwner(userEmail);
      }

      match /category_rules/{ruleId} {
        allow read, write: if isOwner(userEmail);
      }

      match /goals/{goalId} {
        allow read, write: if isOwner(userEmail);
      }

      match /loans/{loanId} {
        allow read, write: if isOwner(userEmail);
      }

      match /challenges/{challengeId} {
        allow read, write: if isOwner(userEmail);
      }

      // Per-asset subcollections for AssetDetailScreen
      match /{collection}/{docId} {
        allow read, write: if isOwner(userEmail) && collection in [
          // Liquid & Fixed Income
          'fd_accounts', 'ppf_accounts', 'post_office_schemes',
          'bonds', 'chit_funds',
          // Equity & Growth
          'stock_holdings', 'sip_holdings', 'etf_holdings',
          'foreign_stocks', 'startup_investments',
          // Retirement
          'pf_accounts', 'vpf_accounts', 'nps_accounts',
          // Alternative Assets
          'gold_holdings', 'sgb_holdings', 'jewelry_items',
          'crypto_holdings', 'reit_holdings', 'p2p_loans',
          // Physical Assets
          'agri_land', 'properties', 'vehicles',
          // Protection & Business
          'insurance_policies', 'business_assets',
          // Liabilities
          'bnpl_entries', 'credit_cards',
        ];
      }
    }

    // App Config — allow all authenticated users to read SMS rules, payment settings, etc.
    match /app_config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
