rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(email) {
      return request.auth != null && request.auth.token.email == email;
    }

    function isAdmin() {
      let adminDoc = get(/databases/$(database)/documents/users/$(request.auth.token.email));
      return request.auth != null
          && adminDoc != null
          && adminDoc.data != null
          && adminDoc.data.isAdmin == true;
    }

    function validTransaction() {
      let d = request.resource.data;
      return d.keys().hasAll(['amount', 'date', 'senderId', 'recipientId'])
          && d.amount is number
          && d.date is timestamp;
    }

    match /users/{userEmail} {
      allow read: if isOwner(userEmail) || isAdmin();
      allow write: if isOwner(userEmail);

      match /transactions/{txId} {
        allow read: if isOwner(userEmail) || isAdmin();
        allow write: if isOwner(userEmail) && (request.method == 'delete' || validTransaction());
      }

      match /categories/{catId} {
        allow read, write: if isOwner(userEmail);
      }

      match /budgets/{catId} {
        allow read, write: if isOwner(userEmail);
      }

      match /recurring_payments/{paymentId} {
        allow read, write: if isOwner(userEmail);
      }

      match /notifications/{notifId} {
        allow read, write: if isOwner(userEmail);
      }

      match /lent_money/{entryId} {
        allow read, write: if isOwner(userEmail);
      }

      match /wealth/{docId} {
        allow read, write: if isOwner(userEmail);
      }

      match /category_rules/{ruleId} {
        allow read, write: if isOwner(userEmail);
      }

      match /goals/{goalId} {
        allow read, write: if isOwner(userEmail);
      }

      match /loans/{loanId} {
        allow read, write: if isOwner(userEmail);
      }

      match /challenges/{challengeId} {
        allow read, write: if isOwner(userEmail);
      }
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
